msgid "Homepage"
msgstr "עמוד הבית"

#: includes/class-admin.php:332 includes/class-fields.php:130
msgid "Blog Page"
msgstr "עמוד הבלוג"

#: includes/class-admin.php:337
#. Group name for Homepage and Blog Page
msgid "Special"
msgstr "דפים מיוחדים"

#: includes/class-admin.php:354 includes/class-fields.php:140
#, php-format
msgid "All %s"
msgstr "כל ה%s"

#: includes/class-admin.php:360
msgid "Post Types"
msgstr "סוגי תוכן"

#: includes/class-fields.php:87
msgid "Search..."
msgstr "חיפוש..."

#: includes/class-fields.php:154
#, php-format
msgid "Post #%d"
msgstr "תוכן #%d"

