#: includes/class-admin.php:28
#. When to trigger/show the popup
msgid "Trigger Settings"
msgstr "מתי להציג"

#: includes/class-admin.php:37
#. Cookie remembers if user saw it, scheduling controls dates
msgid "Cookie & Scheduling"
msgstr "תזמון ותדירות"

#: includes/class-admin.php:46
#. Size constraints for the popup
msgid "Display Constraints"
msgstr "גודל הפופאפ"

#: includes/class-admin.php:55
#. Rules for which pages to show/hide
msgid "Display Rules"
msgstr "באילו דפים להציג"

#: includes/class-admin.php:64
msgid "Popup Content"
msgstr "תוכן הפופאפ"

#: includes/class-admin.php:79
#. Shows when user moves mouse toward closing the tab/window
msgid "Exit Intent"
msgstr "כשהגולש עוזב"

#: includes/class-admin.php:80
#. Shows after X seconds delay
msgid "Timeout"
msgstr "לאחר השהיה"

#: includes/class-admin.php:82
msgid "Trigger Type"
msgstr "מתי יופיע"

#: includes/class-admin.php:87
msgid "Timeout (seconds)"
msgstr "השהיה (שניות)"

#: includes/class-admin.php:105
#. Identifier to remember if user already saw this popup
msgid "Cookie Key"
msgstr "מזהה לזכירה"

#: includes/class-admin.php:111
#. How long to remember the user saw this (don't show again for X days)
msgid "Cookie Expiry (days)"
msgstr "אל תציג שוב למשך (ימים)"

#: includes/class-admin.php:118
msgid "Schedule Start Date (optional)"
msgstr "התחל להציג מתאריך (אופציונלי)"

#: includes/class-admin.php:123
msgid "Schedule End Date (optional)"
msgstr "הפסק להציג בתאריך (אופציונלי)"

#: includes/class-admin.php:133
msgid "Max Width (px)"
msgstr "רוחב מרבי (פיקסלים)"

#: includes/class-admin.php:140
msgid "Max Height (px or empty for auto)"
msgstr "גובה מרבי (השאר ריק לגובה אוטומטי)"

#: includes/class-admin.php:151
#. Pages where popup WILL show
msgid "Include"
msgstr "הצג בדפים אלה"

#: includes/class-admin.php:152
msgid "Leave empty to show on all pages"
msgstr "השאר ריק להצגה בכל האתר"

#: includes/class-admin.php:153 includes/class-admin.php:159
msgid "Search pages, posts, categories..."
msgstr "חפש דפים, פוסטים, קטגוריות..."

#: includes/class-admin.php:157
#. Pages where popup will NOT show
msgid "Exclude"
msgstr "אל תציג בדפים אלה"

#: includes/class-admin.php:158
msgid "Hide popup on these pages"
msgstr "הפופאפ לא יופיע בדפים אלה"

#: includes/class-admin.php:175
msgid "Desktop"
msgstr "מחשב"

#: includes/class-admin.php:179
msgid "Mobile"
msgstr "נייד"

#: includes/class-admin.php:181
#. Indicator that mobile is using the same content as desktop
msgid "Using desktop content"
msgstr "זהה למחשב"

#: includes/class-admin.php:194
msgid "Currently using desktop slides on mobile. Add slides below to customize the mobile experience."
msgstr "כרגע מוצג אותו תוכן בנייד ובמחשב. הוסף שקפים למטה להצגת תוכן שונה בנייד."

#: includes/class-admin.php:224
msgid "Add Slide"
msgstr "הוסף שקף"

#: includes/class-admin.php:238 includes/class-admin.php:275
#, php-format
msgid "Slide %d"
msgstr "שקף %d"

#: includes/class-admin.php:239 includes/class-admin.php:276
msgid "Remove"
msgstr "הסר"

