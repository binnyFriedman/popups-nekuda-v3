{
  "name": "popups-nekuda-v3",
  "version": "3.0.0",
  "description": "WordPress popup plugin - zero dependencies",
  "scripts": {
    "build:ts": "tsc",
    "build:scss": "sass src/scss:assets/css --style=compressed --no-source-map",
    "build": "npm run build:ts && npm run build:scss",
    "watch:ts": "tsc -w",
    "watch:scss": "sass --watch src/scss:assets/css",
    "watch": "concurrently \"npm run watch:ts\" \"npm run watch:scss\""
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "sass": "^1.69.0",
    "typescript": "^5.3.0"
  }
}
